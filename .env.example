# ═══════════════════════════════════════════════════
#  Browser-Use Web UI 环境变量配置
#  复制本文件为 .env 并填入你的 API Key
# ═══════════════════════════════════════════════════

# 服务端口（默认 7788）
PORT=7788

# ── 选择一个 AI 供应商，填入对应的 API Key ──

# Anthropic (推荐)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# DeepSeek (便宜)
DEEPSEEK_API_KEY=

# Kimi / 月之暗面
KIMI_API_KEY=

# 智谱 GLM
ZHIPU_API_KEY=

# 通义千问
QWEN_API_KEY=

# ── 浏览器配置 ──

# 是否无头模式 (true/false)，默认 true
HEADLESS=true

# 是否禁用默认浏览器扩展 (uBlock Origin, ClearURLs 等)
# 服务器网络受限无法下载扩展时必须设为 true（默认 true）
DISABLE_DEFAULT_EXTENSIONS=true

# 任务最大步数，默认 50
MAX_STEPS=50

# 任务超时时间（秒），默认 600
TASK_TIMEOUT=600
